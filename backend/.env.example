# =============================================
# VARIÁVEIS DE AMBIENTE — CandeiasNexusCRM
# Copie este arquivo para .env e preencha os valores
# =============================================

# --- Servidor ---
PORT=3001
JWT_SECRET=gere_uma_chave_aleatoria_longa_aqui_min_32_chars
FRONTEND_URL=https://seu-app.netlify.app

# --- Banco de Dados ---
# Local: ./crm.db  |  Railway: /data/crm.db (após criar volume)
DB_PATH=./crm.db

# --- Inteligência Artificial (Google Gemini) ---
GEMINI_API_KEY=sua_chave_gemini_aqui

# --- E-mail (SMTP) ---
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=seu_usuario@email.com
SMTP_PASS=sua_senha_smtp

# --- Backups (AWS S3) --- opcional
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=seu_access_key
AWS_SECRET_ACCESS_KEY=seu_secret_key
AWS_S3_BUCKET=seu-bucket-name
AWS_S3_BACKUP_RETENTION_DAYS=30

# --- SSL (opcional, apenas para HTTPS local) ---
# SSL_KEY_PATH=/caminho/para/privkey.pem
# SSL_CERT_PATH=/caminho/para/fullchain.pem
